@model Foody_EntityLayer.Concrete.Product

@{
    ViewData["Title"] = "CreateProduct";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h1>Create Product</h1>

<div class="container">
    <div class="page-inner">
        <div class="page-header">
            <h3 class="fw-bold mb-3">Products</h3>

            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Add Product</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Create New Product</a>
                </li>
            </ul>
        </div>
        <div class="row">

            <div class="col-md-12">

                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Add Product Panel</div>
                    </div>
                    <div class="card-body">

                        <form method="post">
                            <label>Product Name</label>
                            <input type="text" asp-for="ProductName" class="form-control" />
                            <br />
                            <label>Product Stock</label>
                            <input type="number" asp-for="Stock" class="form-control" />
                            <br />
                            <label>Product Price</label>
                            <input type="text" asp-for="Price" class="form-control" />
                            <br />
                            <label>ImageUrl</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <label>Product Description</label>
                            <input type="text" asp-for="Description" class="form-control" />
                            <br />
                            <label>Product CategoryId</label>
                            @*Burada direk List ciksin diye alttakini yazdik. Kullanici CategoriId'leri bilemeyeceginden list olarak cikariyoruz.*@
                            @*<input type="number" asp-for="CategoryId" class="form-control" />*@
                                                                                       @*Viewbag.KategorilerViewBagi, Controllerden View'e veri tasimak icin kullanilir.*@
                            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.KategorilerViewBagi"></select>
                            <br />
                            <button class="btn btn-primary">Create Product</button>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div> 