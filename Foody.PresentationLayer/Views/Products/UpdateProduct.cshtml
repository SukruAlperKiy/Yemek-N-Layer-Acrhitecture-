@model Foody_EntityLayer.Concrete.Product

@{
    ViewData["Title"] = "UpdateProduct";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h1>UpdateProduct</h1>


<div class="container">
    <div class="page-inner">
        <div class="page-header">
            <h3 class="fw-bold mb-3">Products</h3>

            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Update Product</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Update Product Operation</a>
                </li>
            </ul>
        </div>
        <div class="row">

            <div class="col-md-12">

                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Update Product Panel</div>
                    </div>
                    <div class="card-body">

                        <form method="post">
                            @* burada input type ="hidden" yapildigi icin gozukmuyor.*@
                            <input type="hidden" asp-for="ProductId" class="form-control" />
                            <br />
                            <label>Product Name</label>
                            <input type="text" asp-for="ProductName" class="form-control" />
                            <br />
                            <label>Product Stock</label>
                            <input type="number" asp-for="Stock" class="form-control" />
                            <br />
                            <label>Product Price</label>
                            <input type="number" asp-for="Price" class="form-control" />
                            <br />
                            <label>ImageUrl</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <label>Description</label>
                            <input type="text" asp-for="Description" class="form-control" />
                            <br />
                            <label>Category Name</label>
                            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.urunKategorisi"></select>
                            <br />

                            <button class="btn btn-success">Update Product</button>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

