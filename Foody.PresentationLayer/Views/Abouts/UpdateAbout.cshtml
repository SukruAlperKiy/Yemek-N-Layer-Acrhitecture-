@model Foody_EntityLayer.Concrete.About

@{
    ViewData["Title"] = "UpdateAbout";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h1>UpdateAbout</h1>

<div class="container">
    <div class="page-inner">
        <div class="page-header">
            <h3 class="fw-bold mb-3">Abouts</h3>

            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Update About</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Update About Operation</a>
                </li>
            </ul>
        </div>
        <div class="row">

            <div class="col-md-12">

                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Update About Panel</div>
                    </div>
                    <div class="card-body">

                        <form method="post">
                            @* burada input type ="hidden" yapildigi icin gozukmuyor.*@
                            <input type="hidden" asp-for="AboutId" class="form-control" />
                            <br />
                            <label>About Title</label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>About Description</label>
                            <textarea class="form-control" asp-for="Description" rows="5"></textarea>
                            <label>Hakkimida Image Url</label>
                            <textarea class="form-action" asp-for="ImageUrl"></textarea>
                            @* <input type="text" asp-for="Description" class="form-control" /> *@
                            <br />

                            <button class="btn btn-success">Update About</button>
                            @* <label>Category Status</label> *@

                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

