@model Foody.DtoLayer.Dtos.SliderDtos.GetByIdSliderDto

@{
    ViewData["Title"] = "UpdateSlider";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h1>UpdateSlider</h1>

<div class="container">
    <div class="page-inner">
        <div class="page-header">
            <h3 class="fw-bold mb-3">Slider</h3>

            <ul class="breadcrumbs mb-3">
                <li class="nav-home">
                    <a href="#">
                        <i class="icon-home"></i>
                    </a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Update Slider</a>
                </li>
                <li class="separator">
                    <i class="icon-arrow-right"></i>
                </li>
                <li class="nav-item">
                    <a href="#">Update Slider Operation</a>
                </li>
            </ul>
        </div>
        <div class="row">

            <div class="col-md-12">

                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Update Slider Panel</div>
                    </div>
                    <div class="card-body">

                        <form method="post">
                            @* burada input type ="hidden" yapildigi icin gozukmuyor.*@
                            <input type="hidden" asp-for="SliderId" class="form-control" />
                            <br />
                            <label>Slider Name</label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Slider Image Url</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <button class="btn btn-success">Update Slider</button>
                            @* <label>Category Status</label> *@

                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>